# DEPLOY/.env.example
# Copie este arquivo para DEPLOY/.env e preencha os valores reais.
# NUNCA commite o .env real — ele já está no .gitignore.

# === Evolution API ===
EVOLUTION_API_KEY=troque-por-uma-chave-secreta-forte

# === Banco de Dados (Neon) ===
# Copie a connection string do painel Neon (Settings → Connection string)
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/evolution?sslmode=require

# === Redis (Upstash) ===
# Copie a Redis URL do painel Upstash (Details → Redis URL)
REDIS_URL=rediss://default:senha@host.upstash.io:6379

# === Back-end do Bot ===
# URL pública do back-end — usada pela Evolution API para enviar webhooks
BACKEND_WEBHOOK_URL=https://seudominio.com/api/whatsapp/webhook

# === Configurações gerais ===
NODE_ENV=production
PORT=3001
