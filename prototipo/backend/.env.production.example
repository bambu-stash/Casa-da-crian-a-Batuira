# Copie este arquivo para .env e preencha os valores
# No Fly.io use: fly secrets set CHAVE=valor

ANTHROPIC_API_KEY=sk-ant-...
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-chave
EVOLUTION_INSTANCE=batuira

ORG_NAME=Casa da Criança Batuira
BOT_FALLBACK_PHONE=5511999990000

SUPABASE_URL=https://xxxx.supabase.co
# service_role key do Supabase — necessário p/ cadastro de atendentes via painel (POST /register)
SUPABASE_SERVICE_KEY=

# Segredo fixo para tokens de login local (sem ele, tokens expiram a cada restart)
# Gere um com: openssl rand -hex 32
LOCAL_SECRET=troque-por-um-segredo-aleatorio-forte

# URL do frontend Vercel (separar múltiplas com vírgula)
ALLOWED_ORIGINS=https://seu-app.vercel.app
